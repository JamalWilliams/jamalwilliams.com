---
interface Props {
  quote: string;
  description: string;
  ctaText?: string;
  ctaHref?: string;
  traits?: { label: string; text: string }[];
}

const { 
  quote, 
  description, 
  ctaText = "Read the narrative", 
  ctaHref = "/manifesto",
  traits = [
    { label: "Sovereignty", text: "Owning the infrastructure of your life." },
    { label: "Autonomy", text: "Zero-dependency creative execution." }
  ]
} = Astro.props;
---

<section class="section-light rounded-architectural mx-4 sm:mx-12 overflow-hidden mb-24 relative">
  <!-- Subtle Grain Overly -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/asfalt-dark.png')]"></div>

  <!-- Background Watermark -->
  <div class="absolute inset-0 z-0 flex items-center justify-start pl-12 select-none pointer-events-none overflow-hidden">
    <h2 class="font-architectural text-[20vw] leading-none !text-navy/[0.03] uppercase">
      Manifesto
    </h2>
  </div>

  <div class="container mx-auto px-8 py-32 grid grid-cols-1 lg:grid-cols-12 gap-20 relative z-10">
    <div class="lg:col-span-5 space-y-10">
      <div class="space-y-4">
        <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-navy/40">Philosophy Node</p>
        <h2 class="font-architectural text-6xl sm:text-8xl leading-[0.85] !text-navy m-0">
          THE<br/>MANIFESTO
        </h2>
      </div>
      <div class="h-1 w-24 bg-gold"></div>
    </div>

    <div class="lg:col-span-7 space-y-16">
      <div class="space-y-10">
        <p class="text-3xl sm:text-5xl leading-tight font-light text-navy tracking-tight italic">
          "{quote}"
        </p>
        <p class="text-xl sm:text-2xl text-navy/70 leading-snug font-light max-w-2xl">
          {description}
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-12 border-t border-navy/10">
        {traits.map(trait => (
          <div class="space-y-3">
            <span class="font-mono text-[10px] uppercase tracking-[0.3em] font-black text-gold">{trait.label}</span>
            <p class="text-lg font-medium text-navy leading-relaxed">{trait.text}</p>
          </div>
        ))}
      </div>

      <div class="pt-8">
        <a href={ctaHref} class="btn-pill scale-110 origin-left">
          <span>{ctaText}</span>
          <span class="btn-pill-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
