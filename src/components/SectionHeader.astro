---
interface Props {
  title: string;
  subtitle?: string;
  quote?: string;
}

const { title, subtitle, quote } = Astro.props;
---

<div class="flex flex-col md:flex-row md:items-end justify-between gap-12 border-t border-white/10 pt-20 mb-20">
  <div class="space-y-6">
    <p class="font-mono text-[10px] text-gold uppercase tracking-[0.4em]">{subtitle || 'Section'}</p>
    <h2 class="font-architectural text-7xl text-white uppercase tracking-tighter m-0">{title}</h2>
  </div>
  {quote && (
    <p class="max-w-sm text-lg text-white/30 leading-snug italic font-light">
      "{quote}"
    </p>
  )}
</div>
