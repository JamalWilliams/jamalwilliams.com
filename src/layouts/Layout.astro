---
import { SEO } from 'astro-seo';
import '../styles/global.css';
import { getCollection, getEntry } from 'astro:content';
import GoogleAnalytics from '../components/analytics/GoogleAnalytics.astro';

interface Props {
	title: string;
	description?: string;
	fullWidth?: boolean;
}

const { title, description = "Sovereign Architect & Storyteller.", fullWidth = false } = Astro.props;

// Fetch navigation settings from homepage
const homepage = await getEntry('pages', 'homepage');
const menuOrder = homepage?.data.menu || ['about', 'principles', 'stack', 'blog'];

// Fetch all content for mapping
const allPages = await getCollection('pages');

// Construct navigation links
const navLinks = menuOrder.map(id => {
	if (id === 'blog') {
		return { href: '/blog', label: 'Blog', isActive: Astro.url.pathname.startsWith('/blog') };
	}
	const page = allPages.find(p => p.id === id);
	if (page) {
		const href = `/${page.id}`;
		return { 
			href, 
			label: page.data.title || page.id.charAt(0).toUpperCase() + page.id.slice(1),
			isActive: Astro.url.pathname === href
		};
	}
	return null;
}).filter(Boolean);

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{gaId && <GoogleAnalytics measurementId={gaId} />}
		<SEO
			title={title}
			titleTemplate="%s | Jamal Williams"
			description={description}
			canonical={canonicalURL}
			openGraph={{
				basic: {
					title: `${title} | Jamal Williams`,
					type: "website",
					image: "/media/Jamal_Profile.png",
					url: canonicalURL.toString(),
				},
				optional: {
					siteName: "Jamal Williams",
					description: description,
				}
			}}
			twitter={{
				card: "summary_large_image",
				title: `${title} | Jamal Williams`,
				description: description,
				image: "/media/Jamal_Profile.png",
			}}
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Outfit:wght@400;600;700;900&family=JetBrains+Mono&display=swap" rel="stylesheet">
	</head>
	<body class="bg-navy text-gray font-sans selection:bg-gold/30 relative min-h-screen overflow-x-hidden pt-24 sm:pt-32">
		<!-- Subtle Grain Overly -->
		<div class="fixed inset-0 z-50 opacity-[0.02] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/asfalt-dark.png')]"></div>

		<!-- Background Branding Mark (Architectural Watermark) -->
		<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden select-none flex items-center justify-center opacity-[0.03]">
			<span class="font-architectural text-[28vw] leading-none whitespace-nowrap text-white">SOVEREIGN</span>
		</div>

		<!-- Decorative background glows -->
		<div class="fixed inset-0 z-0 pointer-events-none selection:bg-transparent">
			<div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-gold/5 blur-[150px] mix-blend-screen opacity-50 animate-float"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-white/5 blur-[120px] mix-blend-screen opacity-40 animate-float" style="animation-delay: -3s;"></div>
		</div>

		<!-- Refined Sticky Navigation -->
		<nav id="main-nav" class="fixed top-8 left-1/2 -translate-x-1/2 z-[60] w-auto min-w-[120px] sm:min-w-0 px-2 py-2 glass rounded-full border border-white/10 shadow-2xl backdrop-blur-3xl transition-all duration-700">
			<div class="flex items-center justify-between gap-1 sm:gap-4">
				<a href="/" class="pl-4 pr-3 py-2 text-white font-display font-black text-xl hover:text-gold transition-colors group flex items-center gap-3">
					<img src="/media/Jamal_Profile.png" alt="Jamal" class="w-8 h-8 rounded-full border border-white/20 object-cover group-hover:scale-110 group-hover:border-gold/50 transition-all duration-500" />
					<span class="hidden sm:inline uppercase tracking-tighter">Williams.</span>
				</a>
				
				<!-- Desktop Menu -->
				<ul class="hidden sm:flex items-center gap-1 pr-1 !list-none">
					{navLinks.map(link => (
						<li class="before:!content-none">
							<a 
								href={link.href} 
								class={`px-6 py-2 rounded-full font-mono text-[11px] uppercase tracking-[0.3em] font-bold transition-all duration-500 ${
									link.isActive 
										? 'bg-gold text-navy shadow-xl shadow-gold/20' 
										: 'text-white/40 hover:text-white hover:bg-white/5'
								}`}
							>
								{link.label}
							</a>
						</li>
					))}
				</ul>

				<!-- Mobile Toggle -->
				<button id="nav-toggle" class="sm:hidden flex items-center justify-center p-2 text-white/40 hover:text-white transition-colors" aria-label="Toggle Menu">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<line x1="4" y1="6" x2="20" y2="6" class="line-top transition-all duration-300"></line>
						<line x1="4" y1="12" x2="20" y2="12" class="line-mid transition-all duration-300"></line>
						<line x1="4" y1="18" x2="20" y2="18" class="line-bot transition-all duration-300"></line>
					</svg>
				</button>
			</div>

			<!-- Mobile Menu Container -->
			<div id="mobile-menu" class="hidden sm:hidden px-4 pb-4 pt-4 border-t border-white/5 mt-2">
				<ul class="flex flex-col gap-3">
					{navLinks.map(link => (
						<li>
							<a 
								href={link.href} 
								class={`block px-6 py-4 rounded-2xl font-mono text-[10px] uppercase tracking-[0.3em] font-bold transition-all duration-500 text-center ${
									link.isActive 
										? 'bg-gold text-navy shadow-xl' 
										: 'text-white/40 hover:text-white hover:bg-white/5'
								}`}
							>
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>
		</nav>

		<script>
			const nav = document.getElementById('main-nav');
			const toggle = document.getElementById('nav-toggle');
			const menu = document.getElementById('mobile-menu');
			const toggleLines = toggle?.querySelectorAll('line');

			toggle?.addEventListener('click', () => {
				const isOpen = menu?.classList.contains('hidden');
				
				if (isOpen) {
					// Open
					menu?.classList.remove('hidden');
					nav?.classList.remove('rounded-full');
					nav?.classList.add('rounded-[2rem]', 'w-[90vw]', 'max-w-[400px]');
					
					if (toggleLines) {
						toggleLines[0].setAttribute('x1', '18'); toggleLines[0].setAttribute('y1', '6'); toggleLines[0].setAttribute('x2', '6'); toggleLines[0].setAttribute('y2', '18');
						toggleLines[1].style.opacity = '0';
						toggleLines[2].setAttribute('x1', '6'); toggleLines[2].setAttribute('y1', '6'); toggleLines[2].setAttribute('x2', '18'); toggleLines[2].setAttribute('y2', '18');
					}
				} else {
					// Close
					menu?.classList.add('hidden');
					nav?.classList.add('rounded-full');
					nav?.classList.remove('rounded-[2rem]', 'w-[90vw]', 'max-w-[400px]');

					if (toggleLines) {
						toggleLines[0].setAttribute('x1', '4'); toggleLines[0].setAttribute('y1', '6'); toggleLines[0].setAttribute('x2', '20'); toggleLines[0].setAttribute('y2', '6');
						toggleLines[1].style.opacity = '1';
						toggleLines[2].setAttribute('x1', '4'); toggleLines[2].setAttribute('y1', '18'); toggleLines[2].setAttribute('x2', '20'); toggleLines[2].setAttribute('y2', '18');
					}
				}
			});

			window.addEventListener('resize', () => {
				if (window.innerWidth >= 640 && !menu?.classList.contains('hidden')) {
					menu?.classList.add('hidden');
					nav?.classList.add('rounded-full');
					nav?.classList.remove('rounded-[2rem]', 'w-[90vw]', 'max-w-[400px]');
				}
			});
		</script>

		<main class={`${fullWidth ? 'w-full' : 'max-w-7xl mx-auto px-6'} relative z-10`}>
			<slot />
		</main>

		<footer class="max-w-7xl mx-auto px-8 py-32 mt-32 border-t border-white/10 relative z-10 flex flex-col lg:flex-row justify-between items-start lg:items-end gap-16">
			<div class="space-y-6">
				<p class="font-architectural text-5xl text-white uppercase tracking-tighter leading-none m-0">Jamal Williams</p>
				<p class="font-mono text-[10px] text-gold uppercase tracking-[0.4em]">Sovereign Architect & Storyteller</p>
			</div>
			
			<div class="flex flex-wrap gap-12 text-white/40 font-mono text-[10px] uppercase tracking-[0.2em] font-bold">
				<a href="https://linkedin.com/in/jamalwilliams" class="hover:text-gold transition-colors">LinkedIn</a>
				<a href="https://github.com/JamalWilliams" class="hover:text-gold transition-colors">GitHub</a>
				<a href="/manifesto" class="hover:text-gold transition-colors underline underline-offset-[12px] decoration-gold/40">The Manifesto</a>
			</div>

			<div class="text-right">
				<p class="font-mono text-[9px] text-white/20 uppercase tracking-[0.5em]">
					&copy; {new Date().getFullYear()} • DETROIT • MI • v3.5.0
				</p>
			</div>
		</footer>
	</body>
</html>
