---
import '../styles/global.css';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Sovereign Storyteller, Photographer, and Digital Architect." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-navy text-light-gray font-sans selection:bg-gold-1/30 relative min-h-screen overflow-x-hidden">
		<!-- Decorative background glows -->
		<div class="fixed inset-0 z-[-1] pointer-events-none selection:bg-transparent">
			<div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-gold-1/5 blur-[120px] mix-blend-screen opacity-60 animate-float"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-light-gray/5 blur-[100px] mix-blend-screen opacity-60 animate-float" style="animation-delay: -3s;"></div>
		</div>

		<main class="max-w-4xl mx-auto px-6 py-12 relative z-10">
			<slot />
		</main>
	</body>
</html>
