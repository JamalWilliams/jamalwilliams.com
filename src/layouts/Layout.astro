---
import '../styles/global.css';
import { getCollection, getEntry } from 'astro:content';

interface Props {
	title: string;
}

const { title } = Astro.props;

// Fetch navigation settings from homepage
const homepage = await getEntry('pages', 'homepage');
const menuOrder = homepage?.data.menu || ['about', 'principles', 'stack', 'blog'];

// Fetch all content for mapping
const allPages = await getCollection('pages');

// Construct navigation links
const navLinks = menuOrder.map(id => {
	if (id === 'blog') {
		return { href: '/blog', label: 'Blog', isActive: Astro.url.pathname.startsWith('/blog') };
	}
	const page = allPages.find(p => p.id === id);
	if (page) {
		const href = `/${page.id}`;
		return { 
			href, 
			label: page.data.title || page.id.charAt(0).toUpperCase() + page.id.slice(1),
			isActive: Astro.url.pathname === href
		};
	}
	return null;
}).filter(Boolean);

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Sovereign Storyteller, Photographer, and Digital Architect." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-navy text-light-gray font-sans selection:bg-gold-1/30 relative min-h-screen overflow-x-hidden pt-20">
		<!-- Decorative background glows -->
		<div class="fixed inset-0 z-[-1] pointer-events-none selection:bg-transparent">
			<div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-gold-1/5 blur-[120px] mix-blend-screen opacity-60 animate-float"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-light-gray/5 blur-[100px] mix-blend-screen opacity-60 animate-float" style="animation-delay: -3s;"></div>
		</div>

		<!-- Sticky Navigation -->
		<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-3rem)] max-w-2xl px-6 py-3 glass rounded-full border border-white/10 shadow-2xl backdrop-blur-xl">
			<div class="flex items-center justify-between">
				<a href="/" class="text-white font-display font-bold text-lg hover:text-gold-1 transition-colors group flex items-center gap-2">
					<img src="/media/Jamal_Profile.png" alt="Jamal" class="w-8 h-8 rounded-full border border-white/20 object-cover group-hover:scale-110 group-hover:border-gold-1/50 transition-all duration-300" />
					<span class="hidden sm:inline">Jamal.</span>
				</a>
				
				<ul class="flex items-center gap-1 sm:gap-2">
					{navLinks.map(link => (
						<li>
							<a 
								href={link.href} 
								class={`px-3 py-1.5 rounded-full text-sm font-medium transition-all duration-300 ${
									link.isActive 
										? 'bg-white/10 text-white shadow-inner' 
										: 'text-light-gray/60 hover:text-white hover:bg-white/5'
								}`}
							>
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>
		</nav>

		<main class="max-w-4xl mx-auto px-6 py-12 relative z-10">
			<slot />
		</main>
	</body>
</html>
