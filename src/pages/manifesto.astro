---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getEntry, render } from 'astro:content';

const manifesto = await getEntry('pages', 'manifesto');
if (!manifesto) {
    return Astro.redirect('/404');
}

const { Content } = await render(manifesto);
---

<Layout title={`${manifesto.data.title} | Jamal Williams`}>
	<section class="py-32 animate-fade-in max-w-5xl mx-auto">
		<header class="mb-24">
			<a href="/" class="font-mono text-[10px] text-gold hover:text-white transition-colors flex items-center gap-2 mb-12 group uppercase tracking-widest">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7" /></svg>
				Return to Core
			</a>
			
			<h1 class="font-architectural text-7xl md:text-[10rem] text-white leading-[0.85] m-0">
				THE<br/>MANIFESTO
			</h1>
			<p class="text-2xl text-white/40 font-light mt-8 max-w-2xl">
				In a world of noise, clarity is the ultimate rebellion. I architect systems that allow the signal to be heard.
			</p>
		</header>

		<div class="glass p-12 md:p-20 rounded-[3rem] animate-slide-up" style="animation-delay: 0.1s;">
			<div class="prose max-w-none">
				<Content />
			</div>
		</div>

		<footer class="mt-20 pt-12 border-t border-white/10 flex justify-between items-center">
			<p class="font-mono text-[10px] opacity-40 uppercase tracking-widest">v3.0 — SOVEREIGN_STORYTELLER</p>
			<a href="/" class="btn-outline">Exit Narrative</a>
		</footer>
	</section>
</Layout>
