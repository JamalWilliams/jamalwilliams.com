---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');

// Sort posts by date descending
posts.sort((a, b) => {
	const dateA = a.data.pubDate?.valueOf() || 0;
	const dateB = b.data.pubDate?.valueOf() || 0;
	return dateB - dateA;
});
---

<Layout title="Blog | Jamal Williams">
	<section class="space-y-12 py-16 animate-fade-in">
		<header class="space-y-4 animate-slide-up">
			<h1 class="text-5xl font-bold tracking-tight text-white font-display">
				The Archive
			</h1>
			<p class="text-xl text-light-gray/80 max-w-2xl leading-relaxed">
				Thoughts on digital sovereignty, the visible architecture of stories, and building systems that buy back time.
			</p>
		</header>

		<div class="space-y-6 animate-slide-up" style="animation-delay: 0.2s;">
			{posts.map((post) => (
				<a href={`/blog/${post.id}`} class="block p-8 rounded-3xl glass shadow-xl hover:-translate-y-1 transition-transform group">
					<div class="flex flex-col md:flex-row md:items-baseline justify-between gap-4">
						<h2 class="text-2xl font-semibold text-white group-hover:text-gold-1 transition-colors font-display">
							{post.data.title || post.id}
						</h2>
						{post.data.pubDate && (
							<time datetime={post.data.pubDate.toISOString()} class="text-sm text-gold-2/80 font-medium">
								{post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						)}
					</div>
					{post.data.description && (
						<p class="mt-4 text-light-gray/70 leading-relaxed max-w-3xl">
							{post.data.description}
						</p>
					)}
					<div class="mt-6 flex items-center text-gold-1 font-medium text-sm">
						Read more <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>
