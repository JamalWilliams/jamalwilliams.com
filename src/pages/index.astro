---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jamal Williams | Sovereign Storyteller">
	<section class="space-y-16 py-20 animate-fade-in">
		<header class="space-y-6">
			<div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-4 animate-slide-up">
				<img src="/images/Square%20Profile.jpg" alt="Jamal Williams" class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover border-4 border-navy shadow-2xl shadow-gold-1/20 ring-2 ring-gold-1/20 transition-transform hover:scale-105 duration-300" />
				<div class="inline-block px-3 py-1 rounded-full bg-gold-1/10 border border-gold-1/20 text-gold-1 text-sm font-medium">
					Jamal 3.0 • Digital Architect
				</div>
			</div>
			<h1 class="text-6xl font-bold tracking-tight text-white sm:text-8xl leading-tight font-display animate-slide-up" style="animation-delay: 0.1s;">
				Sovereign <span class="text-light-gray/60">by design.</span>
			</h1>
			<p class="text-xl text-light-gray/80 max-w-2xl leading-relaxed animate-slide-up" style="animation-delay: 0.2s;">
				I am an unapologetic generalist. For over two decades, I've bridged the gap between complex code and soulful storytelling. Now, I'm building the systems that allow creators to own their narrative.
			</p>
			<div class="flex gap-4 pt-4 animate-slide-up" style="animation-delay: 0.3s;">
				<a href="#practice" class="btn-primary">View Practice</a>
				<a href="/manifesto" class="btn-secondary">Read Manifesto</a>
			</div>
		</header>

		<section id="practice" class="space-y-8 animate-slide-up" style="animation-delay: 0.4s;">
			<h2 class="text-2xl font-bold text-white border-b border-[#233559] pb-4 font-display">The Practice</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<a href="/practice/jwi" class="group p-8 rounded-3xl glass shadow-2xl">
					<div class="w-12 h-12 rounded-xl bg-gold-1/10 flex items-center justify-center mb-6 text-gold-1 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
					</div>
					<h3 class="text-2xl font-semibold text-white group-hover:text-gold-1 transition-colors font-display">JW Intimates</h3>
					<p class="mt-4 text-light-gray/80 leading-relaxed">Luxury boudoir photography focused on the "Slow Exhale." A sanctuary for the sovereign body to be seen, honored, and mirrored.</p>
					<span class="inline-flex items-center mt-6 text-gold-1 font-medium">Internal Review <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
				</a>
				
				<a href="/practice/nl" class="group p-8 rounded-3xl glass shadow-2xl">
					<div class="w-12 h-12 rounded-xl bg-gold-2/10 flex items-center justify-center mb-6 text-gold-2 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
					</div>
					<h3 class="text-2xl font-semibold text-white group-hover:text-gold-2 transition-colors font-display">A Narrative Lens</h3>
					<p class="mt-4 text-light-gray/80 leading-relaxed">Strategic marketing and digital systems for entrepreneurs who value freedom and integrity over hustle culture.</p>
					<span class="inline-flex items-center mt-6 text-gold-2 font-medium">Digital Architecture <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
				</a>
			</div>
		</section>

		<section id="explore" class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-slide-up" style="animation-delay: 0.5s;">
			<a href="/principles" class="glass p-6 rounded-2xl group">
				<h4 class="text-white font-bold font-display group-hover:text-gold-1 transition-colors">Principles</h4>
				<p class="text-xs text-light-gray/60 mt-1">The internal compass.</p>
			</a>
			<a href="/bio" class="glass p-6 rounded-2xl group">
				<h4 class="text-white font-bold font-display group-hover:text-gold-1 transition-colors">Story</h4>
				<p class="text-xs text-light-gray/60 mt-1">From Austin to Detroit.</p>
			</a>
			<a href="/stack" class="glass p-6 rounded-2xl group">
				<h4 class="text-white font-bold font-display group-hover:text-gold-1 transition-colors">Stack</h4>
				<p class="text-xs text-light-gray/60 mt-1">Sovereign infrastructure.</p>
			</a>
		</section>

		<footer class="pt-12 border-t border-[#233559] flex flex-col md:flex-row justify-between items-center gap-6">
			<p class="text-sm text-light-gray/60">
				&copy; {new Date().getFullYear()} Jamal Williams. Detroit, MI.
			</p>
			<div class="flex gap-6 text-light-gray/60 text-sm">
				<a href="https://linkedin.com/in/jamalwilliams" class="hover:text-white transition-colors">LinkedIn</a>
				<a href="https://instagram.com/jwintimates" class="hover:text-white transition-colors">Instagram</a>
				<a href="https://github.com/joeholla" class="hover:text-white transition-colors">GitHub</a>
			</div>
		</footer>
	</section>
</Layout>
