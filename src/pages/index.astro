---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

const homepage = await getEntry('pages', 'homepage');
const manifestoEntry = await getEntry('pages', 'manifesto');

const heroHeadline = homepage?.data.headline || "Sovereign";
const heroSubHeadline = homepage?.data.subHeadline || "by design.";
const heroDescription = homepage?.data.heroDescription || manifestoEntry?.data.description || "I am an unapologetic generalist. For over two decades, I've bridged the gap between complex code and soulful storytelling. Now, I'm building the systems that allow creators to own their narrative.";
const heroImage = homepage?.data.heroImage || "/media/Jamal_Profile.png";

const pages = await getCollection('pages');
const filteredPages = pages.filter(p => !['homepage', 'manifesto'].includes(p.id));
const threeDoors = filteredPages.slice(0, 3);

const practices = await getCollection('practice');
---

<Layout title="Jamal Williams | Sovereign Storyteller">
	<section class="space-y-16 py-20 animate-fade-in">
		<header class="flex flex-col-reverse lg:flex-row items-center justify-between gap-12 pt-8 pb-12">
			<div class="flex-1 space-y-6">
				<div class="inline-block px-3 py-1 rounded-full bg-gold-1/10 border border-gold-1/20 text-gold-1 text-sm font-medium animate-slide-up">
					Jamal 3.0 • Digital Architect
				</div>
				<h1 class="text-5xl sm:text-7xl font-bold tracking-tight text-white leading-tight font-display animate-slide-up" style="animation-delay: 0.1s;">
					{heroHeadline} <span class="text-light-gray/60">{heroSubHeadline}</span>
				</h1>
				<p class="text-xl text-light-gray/80 max-w-xl leading-relaxed animate-slide-up" style="animation-delay: 0.2s;">
					{heroDescription}
				</p>
				<div class="flex gap-4 pt-4 animate-slide-up" style="animation-delay: 0.3s;">
					<a href="#practice" class="btn-primary">View Practice</a>
					<a href="/manifesto" class="btn-secondary">Read Manifesto</a>
				</div>
			</div>
			
			<div class="flex-1 flex justify-center lg:justify-end animate-slide-up pointer-events-none" style="animation-delay: 0.4s;">
				<img 
					src={heroImage} 
					alt="Jamal Williams" 
					class="w-full max-w-md lg:max-w-lg object-contain drop-shadow-[0_20px_50px_rgba(20,33,61,0.5)]" 
				/>
			</div>
		</header>

		<section id="practice" class="space-y-8 animate-slide-up" style="animation-delay: 0.4s;">
			<h2 class="text-2xl font-bold text-white border-b border-[#233559] pb-4 font-display">The Practice</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{practices.map((item) => {
					const isGold2 = item.data.accentColor === 'gold-2';
					const logoSrc = `/images/logo_${item.id.replace(/-/g, '_')}.png`;
					return (
					<a href={`/practice/${item.id}`} class="group p-8 rounded-3xl glass shadow-2xl flex flex-col justify-between">
						<div>
							<div class="h-16 flex items-center justify-start mb-6 transition-transform group-hover:scale-105">
								<img src={logoSrc} alt={item.data.title || item.id} class="h-full w-auto object-contain drop-shadow-md" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
								<div class={`hidden w-12 h-12 rounded-xl items-center justify-center ${isGold2 ? 'bg-gold-2/10 text-gold-2' : 'bg-gold-1/10 text-gold-1'}`}>
									<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										{item.data.icon === 'camera' ? (
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
										) : item.data.icon === 'bolt' ? (
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
										) : (
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
										)}
									</svg>
								</div>
							</div>
							<h3 class={`text-2xl font-semibold text-white transition-colors font-display ${isGold2 ? 'group-hover:text-gold-2' : 'group-hover:text-gold-1'}`}>{item.data.title || item.id}</h3>
							{item.data.description && <p class="mt-4 text-light-gray/80 leading-relaxed line-clamp-3">{item.data.description}</p>}
						</div>
						<span class={`inline-flex items-center mt-6 font-medium ${isGold2 ? 'text-gold-2' : 'text-gold-1'}`}>View Practice <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg></span>
					</a>
				)})}
			</div>
		</section>

		<section id="explore" class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-slide-up" style="animation-delay: 0.5s;">
			{threeDoors.map((door) => (
				<a href={`/${door.id}`} class="glass p-6 rounded-2xl group">
					<h4 class="text-white font-bold font-display group-hover:text-gold-1 transition-colors">
						{door.data.title || door.id.charAt(0).toUpperCase() + door.id.slice(1)}
					</h4>
					<p class="text-xs text-light-gray/60 mt-1">
						{door.data.description || (door.id === 'about' ? 'The Sovereign Architect Story.' : `Learning the ${door.id}.`)}
					</p>
				</a>
			))}
		</section>

		<footer class="pt-12 border-t border-[#233559] flex flex-col md:flex-row justify-between items-center gap-6">
			<p class="text-sm text-light-gray/60">
				&copy; {new Date().getFullYear()} Jamal Williams. Detroit, MI.
			</p>
			<div class="flex gap-6 text-light-gray/60 text-sm">
				<a href="https://linkedin.com/in/jamalwilliams" class="hover:text-white transition-colors">LinkedIn</a>
				<a href="https://github.com/JamalWilliams" class="hover:text-white transition-colors">GitHub</a>
			</div>
		</footer>
	</section>
</Layout>
