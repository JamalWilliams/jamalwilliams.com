---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import PracticeCard from '../components/PracticeCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ManifestoSection from '../components/ManifestoSection.astro';
import { getCollection, getEntry } from 'astro:content';

const homepage = await getEntry('pages', 'homepage');

const heroHeadline = homepage?.data.headline || "SOVEREIGN";
const heroSubHeadline = homepage?.data.subHeadline || "BY DESIGN.";
const heroDescription = homepage?.data.heroDescription || "I am an unapologetic generalist. For over two decades, I've bridged the gap between complex code and soulful storytelling. I architect the digital and creative systems that empower radical autonomy.";
const heroImage = homepage?.data.heroImage || "/images/hero_graphic_transparent.png";
const practiceQuote = homepage?.data.practiceQuote || "Digital architecture is more than just code; it is the construction of ecosystems that prioritize freedom and integrity.";
const manifestoQuote = homepage?.data.manifestoQuote || "In a world of noise, clarity is the ultimate rebellion. I architect systems that allow the signal to be heard.";

const practices = await getCollection('practice');
const marqueeItems = ["Sovereign Storytelling", "Agentic Systems", "Radical Rest", "Digital Architecture", "Detroit Grit"];
---

<Layout title="Jamal Williams | Sovereign Architect" fullWidth={true}>
	<Hero 
		headline={heroHeadline}
		subHeadline={heroSubHeadline}
		description={heroDescription}
		image={heroImage}
	/>

	<Marquee items={marqueeItems} />

	<!-- PRACTICE SECTION -->
	<section id="practice" class="container mx-auto px-6 py-48 space-y-24">
		<SectionHeader 
			title="The Practice"
			subtitle="Strategic Ecosystems & Artistic Storytelling"
			quote={practiceQuote}
		/>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24">
			{practices.map((item, index) => (
				<PracticeCard 
					id={item.id}
					title={item.data.title || ""}
					description={item.data.description || ""}
					index={index}
				/>
			))}
		</div>
	</section>

	<ManifestoSection 
		quote={manifestoQuote}
		description="Whether through the lens of a camera or the architecture of a digital system, the goal is the same: to create a sanctuary where the work can breathe, resonate, and endure. No corporate fluff. Just the raw architecture of sovereignty."
	/>
</Layout>
